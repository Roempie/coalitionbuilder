{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport UserService from '../services/UserService';\nexport default {\n  name: \"Login\",\n  data() {\n    return {\n      user: {\n        email: '',\n        password: ''\n      },\n      loading: false,\n      timeout: null,\n      failedLogin: false\n    };\n  },\n  methods: {\n    async submit() {\n      try {\n        this.loading = true;\n        let response = await UserService.authenticate(this.user);\n        this.loading = false;\n        let token = response.data.token;\n        localStorage.clear();\n        localStorage.setItem(\"token\", token);\n        localStorage.setItem(\"user_email\", this.user.email);\n        // navigate to a protected resource \n        this.$router.push(\"/dashboard\");\n      } catch (err) {\n        this.failedLogin = true;\n        this.loading = false;\n        console.log(err.response);\n      }\n    }\n  },\n  computed: {\n    isButtonDisabled() {\n      this.failedLogin = false;\n      return this.user.email.trim().length === 0 || this.user.password.trim().length === 0;\n    }\n  }\n};","map":{"version":3,"names":["UserService","name","data","user","email","password","loading","timeout","failedLogin","methods","submit","response","authenticate","token","localStorage","clear","setItem","$router","push","err","console","log","computed","isButtonDisabled","trim","length"],"sources":["/Users/rruiter/Desktop/coalitionbuilder/coalitionbuilder_fe/src/components/Login.vue"],"sourcesContent":["<template>\n  <div class=\"text-h3 text-center mb-6\" width=\"300px\">Login</div>\n  <v-sheet width=\"300\" class=\"mx-auto\">\n    <v-form validate-on=\"submit lazy\" @submit.prevent=\"submit\">\n      <v-text-field\n        v-model=\"user.email\"\n        label=\"Email\"\n        type=\"email\"\n        variant=\"underlined\"\n        required\n      ></v-text-field>\n\n      <v-text-field\n        v-model=\"user.password\"\n        label=\"Password\"\n        type=\"password\"\n        variant=\"underlined\"\n        required\n      ></v-text-field>\n      <span v-if=\"failedLogin\" class=\"text-caption text-red-darken-3\"><b>Email or password is incorrect.</b></span>      \n\n      <v-btn :disabled=\"isButtonDisabled\" :loading=\"loading\" type=\"submit\" block class=\"mt-2\">Login</v-btn>\n    </v-form>\n    <router-link style=\"text-decoration: none; color: inherit;\" to=\"/register\"><div class=\"text-caption text-right mt-10\">Sign up</div> </router-link>\n    \n  </v-sheet>\n   \n  \n</template>\n \n <script>\n import UserService from '../services/UserService';\n \n export default {\n   name: \"Login\",\n   data() {\n    return {\n        user: {\n          email: '',\n          password: ''\n        },\n        loading: false,\n        timeout: null,\n        failedLogin: false\n    }\n   },\n   methods: {\n     async submit() {\n      try {\n        this.loading = true;\n        let response = await UserService.authenticate(this.user);\n        this.loading = false;\n        let token = response.data.token;\n\n        localStorage.clear();\n        localStorage.setItem(\"token\", token);\n        localStorage.setItem(\"user_email\", this.user.email);\n        // navigate to a protected resource \n        this.$router.push(\"/dashboard\");\n      } catch (err) {\n        this.failedLogin = true;\n        this.loading = false;\n        console.log(err.response);\n      }\n     }\n   },\n   computed: {\n    isButtonDisabled() {\n        this.failedLogin = false;\n        return this.user.email.trim().length === 0 || this.user.password.trim().length === 0\n    }\n   }\n };\n </script>"],"mappings":";AA+BC,OAAOA,WAAU,MAAO,yBAAyB;AAEjD,eAAe;EACbC,IAAI,EAAE,OAAO;EACbC,IAAIA,CAAA,EAAG;IACN,OAAO;MACHC,IAAI,EAAE;QACJC,KAAK,EAAE,EAAE;QACTC,QAAQ,EAAE;MACZ,CAAC;MACDC,OAAO,EAAE,KAAK;MACdC,OAAO,EAAE,IAAI;MACbC,WAAW,EAAE;IACjB;EACD,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,MAAMA,CAAA,EAAG;MACd,IAAI;QACF,IAAI,CAACJ,OAAM,GAAI,IAAI;QACnB,IAAIK,QAAO,GAA