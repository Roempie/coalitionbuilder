{"ast":null,"code":"import UserService from '../services/UserService';\nimport { onMounted } from 'vue';\nimport { ref } from 'vue';\nexport default {\n  name: \"Dashboard\",\n  setup() {\n    const user = ref(null);\n    onMounted(async () => {\n      let response = await UserService.info(localStorage.getItem(\"user_email\"), localStorage.getItem(\"token\"));\n      user.value = response.data;\n    });\n    return {\n      user\n    };\n  }\n};","map":{"version":3,"names":["UserService","onMounted","ref","name","setup","user","response","info","localStorage","getItem","value","data"],"sources":["/Users/rruiter/Desktop/coalitionbuilder/coalitionbuilder_fe/src/components/Dashboard.vue"],"sourcesContent":["<template>\n    <h1>Dashboard</h1>\n    <div v-if=\"user\">{{ user }}</div>\n</template>\n\n\n<script>\nimport UserService from '../services/UserService';\nimport { onMounted } from 'vue';\n\nimport { ref } from 'vue';\n\nexport default {\n name: \"Dashboard\",\n setup() {\n   const user = ref(null);\n\n   onMounted(async () => {\n     let response = await UserService.info(localStorage.getItem(\"user_email\"), localStorage.getItem(\"token\"))\n     user.value = response.data;\n   });\n\n   return { user };\n },\n};\n\n</script>"],"mappings":"AAOA,OAAOA,WAAU,MAAO,yBAAyB;AACjD,SAASC,SAAQ,QAAS,KAAK;AAE/B,SAASC,GAAE,QAAS,KAAK;AAEzB,eAAe;EACdC,IAAI,EAAE,WAAW;EACjBC,KAAKA,CAAA,EAAG;IACN,MAAMC,IAAG,GAAIH,GAAG,CAAC,IAAI,CAAC;IAEtBD,SAAS,CAAC,YAAY;MACpB,IAAIK,QAAO,GAAI,MAAMN,WAAW,CAACO,IAAI,CAACC,YAAY,CAACC,OAAO,CAAC,YAAY,CAAC,EAAED,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC;MACvGJ,IAAI,CAACK,KAAI,GAAIJ,QAAQ,CAACK,IAAI;IAC5B,CAAC,CAAC;IAEF,OAAO;MAAEN;IAAK,CAAC;EACjB;AACD,CAAC"},"metadata":{},"sourceType":"module","externalDependencies":[]}